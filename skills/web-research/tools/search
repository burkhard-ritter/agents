#!/usr/bin/env -S deno run --allow-net
// search: query DuckDuckGo and return structured results.
// Usage: search <query> [num_results]

import { DOMParser } from "jsr:@b-fuze/deno-dom";

const [query, numResultsArg] = Deno.args;
const numResults = parseInt(numResultsArg ?? "5");

if (!query) {
  console.error("Usage: search <query> [num_results]");
  console.error("Example: search 'deno typescript' 10");
  Deno.exit(1);
}

console.log(`# Search Results for: ${query}\n`);

// ---------------------------------------------------------------------------
// 1. Fetch DuckDuckGo HTML search page
// ---------------------------------------------------------------------------
let html: string;
try {
  const res = await fetch(
    `https://html.duckduckgo.com/html/?q=${encodeURIComponent(query)}`,
    {
      headers: {
        "User-Agent":
          "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 " +
          "(KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml",
        "Accept-Language": "en-US,en;q=0.9",
      },
    },
  );
  if (!res.ok) throw new Error(`HTTP ${res.status} ${res.statusText}`);
  html = await res.text();
} catch (e) {
  console.error(`Error fetching search results: ${(e as Error).message}`);
  Deno.exit(1);
}

// ---------------------------------------------------------------------------
// 2. Parse HTML
// ---------------------------------------------------------------------------
const doc = new DOMParser().parseFromString(html, "text/html")!;

// Detect bot / CAPTCHA page
if (doc.querySelector(".anomaly-modal__box")) {
  console.error(
    "DuckDuckGo returned a bot-detection page.\n" +
      "This can happen with certain IPs or after repeated requests.\n" +
      "Try again in a few minutes, or use `fetch` with a known URL instead.",
  );
  Deno.exit(1);
}

// ---------------------------------------------------------------------------
// 3. Extract results
// ---------------------------------------------------------------------------

/** Resolve DuckDuckGo's redirect wrapper, e.g. /?uddg=<encoded-url> */
function resolveUrl(raw: string): string {
  const uddg = raw.match(/[?&]uddg=([^&]+)/)?.[1];
  return uddg ? decodeURIComponent(uddg) : raw;
}

const resultEls = Array.from(doc.querySelectorAll(".result")).slice(
  0,
  numResults,
);

let count = 0;
for (const result of resultEls) {
  const titleEl = result.querySelector(".result__a");
  if (!titleEl) continue;

  const title = titleEl.textContent?.trim();
  const snippet = result.querySelector(".result__snippet")?.textContent?.trim();
  const url = resolveUrl(titleEl.getAttribute("href") ?? "");

  count++;
  console.log(`## ${count}. ${title}\n`);
  console.log(`**URL:** ${url}\n`);
  if (snippet) console.log(`${snippet}\n`);
}

if (count === 0) {
  console.log(
    "No results found. " +
      "DuckDuckGo may have changed its HTML format — " +
      "check https://html.duckduckgo.com/html/?q=test in a browser to verify.",
  );
}
